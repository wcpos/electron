{
  "extends": "@wcpos/tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "esnext"
    ],
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "public",
    "src"
  ]
}
