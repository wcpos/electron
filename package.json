{
	"name": "@wcpos/app-electron",
	"license": "MIT",
	"productName": "WCPOS",
	"version": "1.9.3",
	"description": "WCPOS desktop client",
	"author": "Paul Kilmurray <paul@wcpos.com>",
	"packageManager": "pnpm@10.31.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"electron",
			"rxdb-premium"
		]
	},
	"main": ".webpack/main",
	"scripts": {
		"dev": "concurrently \"pnpm run dev:expo\" \"pnpm run dev:electron\"",
		"dev:expo": "ELECTRON=true EXPO_NO_METRO_LAZY=true BROWSER=none pnpm --filter @wcpos/main dev --web --port ${EXPO_PORT:-8088} --clear",
		"dev:electron": "NODE_ENV=\"development\" electron-forge start --enable-logging",
		"rebuild:all": "electron-rebuild -f -o better-sqlite3 && electron-rebuild -f -o usb",
		"package": "DEBUG=electron-osx-sign* electron-forge package",
		"make": "electron-forge make",
		"publish-app": "electron-forge publish",
		"lint": "eslint src --ext .js,.jsx,.ts,.tsx",
		"lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
		"test": "pnpm run test:preload && pnpm run test:printer-discovery && pnpm run test:rxdb-ipc-attachments && pnpm run test:image-cache && pnpm run test:package-runtime-externals",
		"ts:check": "tsc --noEmit",
		"test:preload": "ts-node src/preload.test.ts",
		"test:rxdb-ipc-attachments": "ts-node src/rxdb-ipc-attachments.test.ts",
		"test:image-cache": "ts-node src/main/image-cache.test.ts",
		"test:printer-discovery": "ts-node src/main/printer-discovery.test.ts",
		"test:package-runtime-externals": "ts-node --transpile-only test/package-runtime-externals.test.ts"
	},
	"dependencies": {
		"@sentry/electron": "^7.1.0",
		"axios": "^1.15.2",
		"better-sqlite3": "12.10.0",
		"bonjour-service": "1.4.0",
		"electron-log": "^5.4.3",
		"electron-serve": "^3.0.0",
		"i18next": "^26.0.0",
		"rxdb": "17.2.0",
		"rxdb-premium": "17.2.0",
		"rxjs": "7.8.2",
		"semver": "^7.6.3",
		"usb": "2.18.0"
	},
	"devDependencies": {
		"@electron-forge/cli": "^7.8.3",
		"@electron-forge/maker-deb": "^7.8.3",
		"@electron-forge/maker-dmg": "^7.8.3",
		"@electron-forge/maker-flatpak": "^7.8.3",
		"@electron-forge/maker-rpm": "^7.8.3",
		"@electron-forge/maker-squirrel": "^7.8.3",
		"@electron-forge/maker-zip": "^7.8.3",
		"@electron-forge/plugin-auto-unpack-natives": "^7.8.3",
		"@electron-forge/plugin-webpack": "^7.8.3",
		"@electron-forge/publisher-github": "^7.8.3",
		"@electron-forge/shared-types": "^7.8.3",
		"@electron/rebuild": "^4.0.1",
		"@types/better-sqlite3": "^7.6.12",
		"@types/fs-extra": "^11.0.4",
		"@types/webpack-node-externals": "^3.0.4",
		"@typescript-eslint/eslint-plugin": "^8.60.0",
		"@typescript-eslint/parser": "^8.60.0",
		"@vercel/webpack-asset-relocator-loader": "1.10.0",
		"@wcpos/eslint-config": "^2.0.0",
		"concurrently": "^9.2.1",
		"electron": "41.7.1",
		"electron-debug": "^4.1.0",
		"electron-devtools-installer": "4.0.0",
		"electron-squirrel-startup": "^1.0.1",
		"electron-store": "^11.0.0",
		"eslint": "^9.39.2",
		"fs-extra": "^11.2.0",
		"node-loader": "^2.1.0",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"typescript": "5.9.3"
	}
}
