{
	"name": "@wcpos/app-electron",
	"version": "1.0.0",
	"private": true,
	"author": "kilbot <paul@kilbot.com>",
	"description": "Electron Desktop App for WooCommerce POS",
	"main": "./public/electron.js",
	"homepage": "./",
	"scripts": {
		"cra:start": "craco start",
		"cra:build": "craco build",
		"build": "craco build",
		"start": "concurrently -k \"cross-env BROWSER=none yarn cra:start\" \"wait-on http://localhost:3000 && electronmon .\"",
		"package:mac": "yarn cra:build && electron-builder -m -c.extraMetadata.main=build/electron.js",
		"package:win": "yarn cra:build && electron-builder -w -c.extraMetadata.main=build/electron.js",
		"package:linux": "yarn cra:build && electron-builder -l -c.extraMetadata.main=build/electron.js",
		"test": "react-scripts test --watchAll=false --passWithNoTests",
		"eject": "react-scripts eject",
		"lint": "eslint .",
		"lint:fix": "yarn lint --fix"
	},
	"dependencies": {
		"@react-native-async-storage/async-storage": "1.17.3",
		"@testing-library/jest-dom": "5.16.4",
		"@testing-library/react": "11.2.7",
		"@testing-library/user-event": "12.8.3",
		"@wcpos/hello-world": "wcpos/hello-world",
		"react": "17.0.2",
		"react-dom": "17.0.2",
		"react-native": "0.64.3",
		"react-native-web": "0.17.7",
		"react-scripts": "4.0.3"
	},
	"devDependencies": {
		"@craco/craco": "6.4.3",
		"@types/react": "17.0.44",
		"@types/react-dom": "17.0.15",
		"@wcpos/babel": "*",
		"@wcpos/eslint": "*",
		"@wcpos/tsconfig": "*",
		"concurrently": "6.5.1",
		"cross-env": "7.0.3",
		"electron": "14.2.9",
		"electron-builder": "22.14.13",
		"electronmon": "2.0.2",
		"react-native-monorepo-tools": "1.1.4",
		"wait-on": "6.0.1"
	},
	"browserslist": {
		"production": [
			"last 1 electron version"
		],
		"development": [
			"last 1 electron version"
		]
	},
	"build": {
		"appId": "com.wcpos.electron",
		"productName": "WooCommerce POS",
		"files": [
			"build/**/*",
			"node_modules/**/*"
		],
		"directories": {
			"buildResources": "public"
		},
		"mac": {
			"target": "dmg"
		},
		"win": {
			"target": "nsis"
		},
		"linux": {
			"target": "deb"
		}
	}
}
